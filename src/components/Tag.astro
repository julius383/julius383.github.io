---
import IconHash from "@/assets/icons/IconHash.svg";
import { slugifyStr } from "@/utils/slugify";
import type { Tag } from "@/utils/getUniqueTags";

export interface Props {
  tag?: string;
  tagName: string;
  tagCount?: number;
  uniqueTags?: Tag[];
  size?: "sm" | "lg";
}

const { tagName, size = "lg", uniqueTags } = Astro.props;
const tag = Astro.props.tag || slugifyStr(tagName);
const tagCount =
  Astro.props.tagCount ??
  uniqueTags?.find(t => t.tagName === tagName)?.tagCount ??
  1;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "flex items-center gap-0.5 font-mono",
      "border-b-2 border-dashed border-foreground",
      "hover:-mt-0.5 hover:border-accent hover:text-accent",
      "focus-visible:border-none focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-80",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    {tagName}
    <span class="text-gray-300 font-bold">({tagCount})</span>
  </a>
</li>
